<div class="instagram-feed-section" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container" style="max-width: 1440px;">
    {%- if section.settings.heading != blank or section.settings.handle != blank -%}
      <div style="text-align: center; margin-bottom: 40px;">
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: clamp(28px, 4vw, 42px); margin-bottom: 10px;">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.handle != blank -%}
          <p style="font-size: 16px; color: var(--color-text-light);">
            <a href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 5px; color: inherit;">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              {{ section.settings.handle }}
            </a>
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="insta-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
      <style>
        @media (min-width: 768px) {
          .insta-grid { grid-template-columns: repeat({{ section.settings.columns }}, 1fr) !important; gap: 20px !important; }
        }
      </style>
      {%- for block in section.blocks -%}
        <div class="insta-item" {{ block.shopify_attributes }} style="position: relative; aspect-ratio: 1/1; overflow: hidden; border-radius: var(--border-radius);">
          <a href="{{ block.settings.link | default: '#' }}" target="_blank" rel="noopener" style="display: block; width: 100%; height: 100%;">
            {%- if block.settings.image != blank -%}
              <img width="400" height="400" src="{{ block.settings.image | image_url: width: 600 }}" alt="Instagram Post" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            

          </a>
        </div>
      {%- endfor -%}
    </div>
    
    <div style="text-align: center; margin-top: 40px;">
      <a href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" target="_blank" rel="noopener" class="btn btn-outline">Follow Us</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Social Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Social Gallery"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram Handle",
      "default": "@glamourbeauty"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    }
  ],
  "max_blocks": 12,
  "blocks": [
    {
      "type": "image",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Post URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
