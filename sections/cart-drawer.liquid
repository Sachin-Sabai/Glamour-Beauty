<div class="cart-drawer-overlay js-cart-close"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-drawer-header">
    <h2 style="font-size: 24px; font-family: var(--font-heading); margin: 0;">{{ 'cart.general.title' | t }} ({{ cart.item_count }})</h2>
    <button class="cart-drawer-close js-cart-close" aria-label="Close cart">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  
  <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form" class="cart-form" style="display: flex; flex-direction: column; flex-grow: 1; overflow: hidden; height: calc(100% - 70px);">
    <div class="cart-drawer-body" style="flex-grow: 1; overflow-y: auto;">
      {% if cart.item_count > 0 %}
          {% for item in cart.items %}
            <div class="cart-item" style="display: flex; gap: 15px; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--color-border);">
              <div class="cart-item-image" style="width: 80px; flex-shrink: 0;">
                {% if item.image %}
                  <img width="400" height="400" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" style="width: 100%; height: auto; object-fit: cover; border-radius: 4px;">
                {% endif %}
              </div>
              <div class="cart-item-details" style="flex-grow: 1;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                  <h3 style="font-size: 16px; margin-bottom: 5px; font-weight: 500;"><a href="{{ item.url }}" style="text-decoration: none;">{{ item.product.title }}</a></h3>
                  <a href="{{ item.url_to_remove }}" aria-label="{{ 'cart.general.remove' | t }}" class="item-remove" data-line="{{ forloop.index }}" style="color: var(--color-text-light); margin-left: 10px; padding: 5px; display: inline-flex; align-items: center; justify-content: center; min-width: 24px; min-height: 24px;"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" style="pointer-events:none;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg></a>
                </div>
                {%- unless item.product.has_only_default_variant -%}
                  <p style="font-size: 12px; color: var(--color-text-light); margin-bottom: 5px;">{{ item.variant.title }}</p>
                {%- endunless -%}
                <div style="margin-bottom: 10px; display: flex; justify-content: space-between;">
                  <span>{{ item.final_price | money }}</span>
                  <strong class="line-item-total">{{ item.final_line_price | money }}</strong>
                </div>
                
                {% render 'quantity-selector', value: item.quantity, line: forloop.index %}
              </div>
            </div>
          {% endfor %}
          
          {% if settings.show_order_note %}
            <div style="margin-top: 20px;">
              <label for="CartSpecialInstructions" style="display: block; margin-bottom: 5px;">Order Note</label>
              <textarea name="note" id="CartSpecialInstructions" class="form-input" rows="3">{{ cart.note }}</textarea>
            </div>
          {% endif %}
      {% else %}
        <div style="text-align: center; padding: 40px 0;">
          <p>{{ 'cart.general.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary" style="margin-top: 20px;">Continue Shopping</a>
        </div>
      {% endif %}
    </div>
    
    <div class="cart-drawer-footer" style="flex-shrink: 0; {% if cart.item_count == 0 %}display: none;{% endif %}">
      <div style="display: flex; justify-content: space-between; font-size: 18px; font-weight: 500; margin-bottom: 15px;">
        <span>{{ 'cart.general.subtotal' | t }}</span>
        <span class="cart-subtotal">{{ cart.total_price | money }}</span>
      </div>
      <p style="font-size: 12px; color: var(--color-text-light); text-align: center; margin-bottom: 15px;">{{ 'cart.general.shipping_at_checkout' | t }}</p>
      <a href="/checkout" class="btn btn-primary btn-full" style="padding: 16px; font-size: 16px; letter-spacing: 1px; display: block; text-align: center; text-decoration: none;">{{ 'cart.general.checkout' | t }}</a>
    </div>
  </form>
</div>

{% schema %}
{"name": "Cart Drawer"}
{% endschema %}
