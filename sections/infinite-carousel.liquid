<div class="infinite-carousel-section" style="padding: 40px 0; background: {{ section.settings.bg_color }}; overflow: hidden;">
  <div class="container" style="position: relative;">
    
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div style="text-align: center; margin-bottom: 40px;">
        {%- if section.settings.subheading != blank -%}
          <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 14px; color: var(--color-primary); margin-bottom: 10px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: clamp(28px, 4vw, 42px);">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="carousel" data-slides="{{ section.settings.slides_desktop }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
      {%- if section.settings.show_arrows -%}
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      {%- endif -%}

      <div class="carousel-inner">
        {%- if section.settings.mode == 'products' -%}
          {%- assign collection = collections[section.settings.collection] -%}
          {%- if collection == blank -%}
            {%- assign collection = collections['all'] -%}
          {%- endif -%}
          
          {%- for product in collection.products limit: 10 -%}
            <div class="carousel-slide" style="padding: 10px;">
              {% render 'product-card', product_card_product: product, show_secondary_image: true, show_vendor: true, show_rating: true %}
            </div>
          {%- else -%}
            {%- for i in (1..4) -%}
              {%- assign dummy_title = '' -%}
              {%- assign dummy_vendor = '' -%}
              {%- assign dummy_price = '' -%}
              {%- assign dummy_img = '' -%}
              
              {%- case i -%}
                {%- when 1 -%}
                  {%- assign dummy_title = 'Minimalist Niacinamide Serum' -%}
                  {%- assign dummy_vendor = 'Minimalist' -%}
                  {%- assign dummy_price = '₹559' -%}
                  {%- assign dummy_img = 'prod_minimalist.png' -%}
                {%- when 2 -%}
                  {%- assign dummy_title = 'Watermelon Moisturizer' -%}
                  {%- assign dummy_vendor = 'Dot & Key' -%}
                  {%- assign dummy_price = '₹599' -%}
                  {%- assign dummy_img = 'prod_dotkey.png' -%}
                {%- when 3 -%}
                  {%- assign dummy_title = 'Liquid Lipstick' -%}
                  {%- assign dummy_vendor = 'Swiss Beauty' -%}
                  {%- assign dummy_price = '₹349' -%}
                  {%- assign dummy_img = 'prod_swiss.png' -%}
                {%- when 4 -%}
                  {%- assign dummy_title = 'Mamaearth Face Wash' -%}
                  {%- assign dummy_vendor = 'Mamaearth' -%}
                  {%- assign dummy_price = '₹399' -%}
                  {%- assign dummy_img = 'prod_mamaearth.png' -%}
              {%- endcase -%}

              <div class="carousel-slide" style="padding: 10px;">
                <div class="product-card">
                  <div class="product-card-image-wrapper">
                    <a href="{{ routes.all_products_collection_url }}" class="product-card-link">
                      <img src="{{ dummy_img | asset_url }}" alt="{{ dummy_title }}" width="400" height="400" class="product-card-image" loading="lazy">
                    </a>
                  </div>
                  <div class="product-card-info" style="text-align: left;">
                    <div class="product-card-brand">{{ dummy_vendor }}</div>
                    <h3 class="product-card-title"><a href="{{ routes.all_products_collection_url }}">{{ dummy_title }}</a></h3>
                    <div class="product-card-price">{{ dummy_price }}</div>
                    <div class="product-card-actions" style="margin-top: 15px;">
                      <form method="post" action="{{ routes.cart_add_url }}">
                        <input type="hidden" name="id" value="1">
                        <button type="submit" class="btn btn-primary btn-full" style="border-radius: 6px;">Add to Cart</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endfor -%}
        
        {%- else -%}
          {%- for block in section.blocks -%}
            <div class="carousel-slide" {{ block.shopify_attributes }} style="padding: 10px;">
              <div style="background: #fff; border-radius: var(--border-radius); overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
                {%- if block.settings.image != blank -%}
                  <img width="400" height="400" src="{{ block.settings.image | image_url: width: 600 }}" alt="" loading="lazy" style="width: 100%; aspect-ratio: 4/3; object-fit: cover;">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                <div style="padding: 30px; text-align: center;">
                  {%- if block.settings.eyebrow != blank -%}
                    <p style="text-transform: uppercase; font-size: 12px; letter-spacing: 1px; color: var(--color-primary); margin-bottom: 10px;">{{ block.settings.eyebrow }}</p>
                  {%- endif -%}
                  {%- if block.settings.heading != blank -%}
                    <h3 style="font-family: var(--font-heading); font-size: 24px; margin-bottom: 15px;">{{ block.settings.heading }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p style="color: var(--color-text-light); margin-bottom: 20px; font-size: 14px;">{{ block.settings.text }}</p>
                  {%- endif -%}
                  {%- if block.settings.btn_label != blank -%}
                    <a href="{{ block.settings.btn_link | default: routes.all_products_collection_url }}" class="btn btn-outline">{{ block.settings.btn_label }}</a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_dots -%}
        <div class="carousel-dots"></div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Infinite Carousel",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF4F4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Discover"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Carousel Mode",
      "options": [
        { "value": "products", "label": "Products" },
        { "value": "custom_slides", "label": "Custom Slides" }
      ],
      "default": "products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (For Product Mode)"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Speed",
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Slides visible on desktop",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Pagination Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Custom Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "New"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Slide Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Brief description for this custom slide."
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infinite Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
