<div class="before-after-section" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div style="text-align: center; margin-bottom: 40px;">
        {%- if section.settings.subheading != blank -%}
          <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 14px; color: var(--color-primary); margin-bottom: 10px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: clamp(28px, 4vw, 42px);">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div style="max-width: 800px; margin: 0 auto;">
      {%- for block in section.blocks -%}
        <div class="before-after-container" style="margin-bottom: 40px; text-align: center;" {{ block.shopify_attributes }}>
          <div class="before-after-wrapper" style="border-radius: var(--border-radius); box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            
            {%- if block.settings.image_after != blank -%}
              <img width="400" height="400" src="{{ block.settings.image_after | image_url: width: 800 }}" alt="After" class="before-after-img" loading="lazy">
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'before-after-img placeholder-svg' }}
            {%- endif -%}
            
            <div class="before-after-overlay">
              {%- if block.settings.image_before != blank -%}
                <img width="400" height="400" src="{{ block.settings.image_before | image_url: width: 800 }}" alt="Before" loading="lazy">
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <span style="position: absolute; top: 20px; left: 20px; background: rgba(0,0,0,0.5); color: #fff; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; letter-spacing: 1px; text-transform: uppercase;">{{ block.settings.label_before }}</span>
            </div>
            
            <div class="before-after-handle"></div>
            
            <span style="position: absolute; top: 20px; right: 20px; background: rgba(0,0,0,0.5); color: #fff; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; z-index: 1;">{{ block.settings.label_after }}</span>
          </div>

          {%- if block.settings.btn_label != blank -%}
            <div style="margin-top: 20px;">
              <a href="{{ block.settings.btn_link }}" class="btn btn-primary">{{ block.settings.btn_label }}</a>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Before / After Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See the Difference"
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Comparison",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "After Image"
        },
        {
          "type": "text",
          "id": "label_before",
          "label": "Before Label",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "label_after",
          "label": "After Label",
          "default": "After 4 Weeks"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop the Routine"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Before / After Slider",
      "blocks": [
        { "type": "comparison" }
      ]
    }
  ]
}
{% endschema %}
