<div class="page-width" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
  <div class="grid">
    <div class="grid__item medium-up--five-sixths medium-up--push-one-twelfth">
      <div class="section-header text-center" style="margin-top: 60px; margin-bottom: 40px; text-align: center;">
        <h1 style="font-size: 36px; font-weight: 600; font-family: var(--font-heading); color: var(--color-text);">
          {{ section.settings.heading | default: page.title }}
        </h1>
      </div>

      <div class="rte" style="max-width: 800px; margin: 0 auto; line-height: 1.6; padding-bottom: 80px; color: var(--color-text);">
        {%- for block in section.blocks -%}
          <div class="faq-item" style="margin-bottom: 30px; {% unless forloop.last %}border-bottom: 1px solid rgba(0,0,0,0.1);{% endunless %} padding-bottom: 20px;" {{ block.shopify_attributes }}>
            <h3 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">{{ block.settings.question }}</h3>
            <div style="opacity: 0.8; font-size: 16px;">{{ block.settings.answer }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We accept returns within 30 days of purchase.</p>"
        }
      ]
    }
  ]
}
{% endschema %}
