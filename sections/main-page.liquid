<div class="page-section" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container" style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-size: clamp(36px, 5vw, 54px); margin-bottom: 40px; text-align: center;">{{ page.title }}</h1>
    <div class="rte" style="line-height: 1.8; font-size: 16px; color: var(--color-text);">
      {{ page.content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
