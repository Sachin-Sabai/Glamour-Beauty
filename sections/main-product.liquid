<div class="product-template" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container">
    {% render 'breadcrumb' %}
    
    <div style="display: flex; flex-wrap: wrap; gap: 40px;">
      
      <!-- Media Gallery -->
      <div class="product-media" style="flex: 1.5; min-width: 300px;">
        <!-- Main Media Display -->
        <div class="product-main-media-container" style="position: relative; border-radius: var(--border-radius); overflow: hidden; margin-bottom: 15px; background: #f9f9f9;">
          {%- for media in product.media -%}
            <div class="product-main-media" data-media-id="{{ media.id }}" style="display: {% if forloop.first %}block{% else %}none{% endif %}; width: 100%; position: relative;">
              {% case media.media_type %}
                {% when 'image' %}
                  <img src="{{ media | image_url: width: 1200 }}" alt="{{ media.alt | escape }}" style="width: 100%; height: auto; display: block; object-fit: contain;" width="{{ media.width }}" height="{{ media.height }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}">
                {% when 'external_video' %}
                  <div style="padding-top: 56.25%; position: relative; width: 100%;">
                    {{ media | external_video_tag: style: 'position: absolute; top: 0; left: 0; width: 100%; height: 100%;', loading: 'lazy' }}
                  </div>
                {% when 'video' %}
                  {{ media | video_tag: controls: true, style: 'width: 100%; height: auto; display: block;' }}
                {% when 'model' %}
                  <div style="padding-top: 100%; position: relative; width: 100%;">
                    {{ media | model_viewer_tag: style: 'position: absolute; top: 0; left: 0; width: 100%; height: 100%;', auto-rotate: true, camera-controls: true }}
                  </div>
                {% else %}
                  {{ media | media_tag: style: 'width: 100%; height: auto; display: block;' }}
              {% endcase %}
              
              {%- if forloop.first -%}
                {% render 'product-badge', product: product %}
              {%- endif -%}
            </div>
          {%- endfor -%}

          <!-- AR Button -->
          {%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
          {%- if first_3d_model -%}
            <button
              class="btn btn--secondary product__xr-button"
              type="button"
              aria-label="View in your space"
              data-shopify-xr
              data-shopify-model3d-id="{{ first_3d_model.id }}"
              data-shopify-title="{{ product.title | escape }}"
              data-shopify-xr-hidden
              style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); z-index: 2; border-radius: 30px; display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: rgba(255,255,255,0.9); border: 1px solid var(--color-border);"
            >
              <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
              <span>View in your space</span>
            </button>
          {%- endif -%}
        </div>

        <!-- Thumbnails -->
        {%- if product.media.size > 1 -%}
          <div class="product-thumbnails" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 10px;">
            {%- for media in product.media -%}
              <button type="button" class="product-thumbnail-btn {% if forloop.first %}is-active{% endif %}" data-media-id="{{ media.id }}" aria-label="Load media {{ forloop.index }} of {{ product.media.size }}" style="border: 2px solid {% if forloop.first %}var(--color-primary){% else %}transparent{% endif %}; padding: 0; background: transparent; cursor: pointer; border-radius: 4px; overflow: hidden; position: relative;">
                <img src="{{ media.preview_image | image_url: width: 150 }}" alt="{{ media.alt | escape }}" width="{{ media.preview_image.width }}" height="{{ media.preview_image.height }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; aspect-ratio: 1/1; display: block;">
                
                {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                  <span class="media-icon" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.6); color: #fff; border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  </span>
                {%- elsif media.media_type == 'model' -%}
                  <span class="media-icon" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.6); color: #fff; border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                  </span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      <!-- Product Info -->
      <div class="product-info" style="flex: 1; min-width: 300px; position: sticky; top: 100px; align-self: start;">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'vendor' -%}
              <div class="product-vendor" {{ block.shopify_attributes }} style="margin-bottom: 15px; font-size: 14px; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 1px;">{{ product.vendor }}</div>
            {%- when 'title' -%}
              <h1 class="product-title" {{ block.shopify_attributes }} style="font-size: clamp(32px, 4vw, 42px); margin-bottom: 15px;">{{ product.title }}</h1>
            {%- when 'price' -%}
              <div class="product-price-wrapper" {{ block.shopify_attributes }} style="font-size: 24px; font-weight: 500; margin-bottom: 20px; color: var(--color-primary);">
                {% render 'price', product: product %}
              </div>
            {%- when 'description' -%}
              <div class="product-description" {{ block.shopify_attributes }} style="font-size: 16px; color: var(--color-text-light); line-height: 1.6; margin-bottom: 30px;">
                {{ product.description }}
              </div>
            {%- when 'variant_picker' -%}
              <div class="product-variant-picker" {{ block.shopify_attributes }}>
                {% render 'variant-picker', product: product %}
              </div>
            {%- when 'buy_buttons' -%}
              <div class="product-buy-buttons" {{ block.shopify_attributes }} style="margin-bottom: 30px;">
                {%- assign product_form_id = 'product-form-' | append: section.id -%}
                {%- form 'product', product, id: product_form_id, class: 'product-form' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                  
                  <div style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 10px; font-weight: 600;">{{ 'cart.label.quantity' | t }}</label>
                    {% render 'quantity-selector', value: 1 %}
                  </div>

                  {%- if product.selling_plan_groups.size > 0 -%}
                    <fieldset class="product-selling-plans" style="border: none; padding: 0; margin-bottom: 20px;">
                      <legend style="font-weight: 600; margin-bottom: 10px;">Purchase Options</legend>
                      <select name="selling_plan" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--border-radius);">
                        <option value="">One-time purchase</option>
                        {%- for group in product.selling_plan_groups -%}
                          <optgroup label="{{ group.name }}">
                            {%- for plan in group.selling_plans -%}
                              <option value="{{ plan.id }}">{{ plan.name }}</option>
                            {%- endfor -%}
                          </optgroup>
                        {%- endfor -%}
                      </select>
                    </fieldset>
                  {%- endif -%}
                  
                  <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 20px;">
                    <button type="submit" name="add" class="btn btn-primary" style="flex: 1; min-width: 200px;" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                      {% if product.selected_or_first_available_variant.available %}
                        {{ 'cart.general.add_to_cart' | t }}
                      {% else %}
                        {{ 'products.product.out_of_stock' | t }}
                      {% endif %}
                    </button>
                    {{ form | payment_button }}
                  </div>
                {%- endform -%}

                <!-- Pickup Availability -->
                <pickup-availability class="pickup-availability-root" data-root-url="{{ routes.root_url }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-has-only-default-variant="{{ product.has_only_default_variant }}" style="display: block; margin-top: 20px;">
                  {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities | where: 'pick_up_enabled', true -%}
                  {%- if pick_up_availabilities.size > 0 -%}
                    <div class="pickup-availability-summary" style="padding: 15px; border: 1px solid var(--color-border); border-radius: var(--border-radius);">
                      <div style="display: flex; gap: 10px; align-items: flex-start;">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                        <div>
                          <p style="font-weight: 600; margin-bottom: 5px;">Pickup available at {{ pick_up_availabilities.first.location.name }}</p>
                          <p style="font-size: 14px; color: var(--color-text-light);">Usually ready in {{ pick_up_availabilities.first.pick_up_time }}</p>
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                </pickup-availability>
              </div>
            {%- when 'collapsible_tab' -%}
              <div class="accordion-item" {{ block.shopify_attributes }}>
                <div class="accordion-title">
                  {{ block.settings.heading | default: block.settings.page.title }}
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                </div>
                <div class="accordion-content">
                  <div class="accordion-content-inner">
                    {{ block.settings.content }}
                    {{ block.settings.page.content }}
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
      
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Information",
  "settings": [],
  "blocks": [
    { "type": "@app" },
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "variant_picker", "name": "Variant Picker", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy Buttons", "limit": 1 },
    { "type": "description", "name": "Description", "limit": 1 },
    {
      "type": "collapsible_tab",
      "name": "Collapsible Row",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Collapsible Row" },
        { "type": "richtext", "id": "content", "label": "Content" },
        { "type": "page", "id": "page", "label": "Page Content" }
      ]
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const thumbnails = document.querySelectorAll('.product-thumbnail-btn');
    const mainMedias = document.querySelectorAll('.product-main-media');

    if (thumbnails.length > 0) {
      thumbnails.forEach(btn => {
        btn.addEventListener('click', function() {
          const mediaId = this.getAttribute('data-media-id');
          
          // Update active thumbnail
          thumbnails.forEach(t => {
            t.classList.remove('is-active');
            t.style.borderColor = 'transparent';
          });
          this.classList.add('is-active');
          this.style.borderColor = 'var(--color-primary)';
          
          // Show active media
          mainMedias.forEach(media => {
            if (media.getAttribute('data-media-id') === mediaId) {
              media.style.display = 'block';
              
              // Pause other videos if present
              const activeVideo = media.querySelector('video');
              if (activeVideo) activeVideo.play();
            } else {
              media.style.display = 'none';
              const inactiveVideo = media.querySelector('video');
              if (inactiveVideo) inactiveVideo.pause();
              
              // Pause YouTube/Vimeo iframe
              const iframe = media.querySelector('iframe');
              if (iframe) {
                const src = iframe.src;
                iframe.src = src; // Reload iframe to stop playing
              }
            }
          });
        });
      });
    }

    // Listen for variant changes from variant-picker.liquid
    document.addEventListener('variant:changed', function(event) {
      const variant = event.detail.variant;
      if (variant && variant.featured_media) {
        const mediaId = variant.featured_media.id.toString();
        const thumbnail = document.querySelector(`.product-thumbnail-btn[data-media-id="${mediaId}"]`);
        if (thumbnail) {
          thumbnail.click();
        }
      }
      
      // Update Pickup Availability
      const pickupAvailability = document.querySelector('pickup-availability');
      if (pickupAvailability && variant) {
        pickupAvailability.setAttribute('data-variant-id', variant.id);
        const url = `${pickupAvailability.dataset.rootUrl}variants/${variant.id}/?section_id=pickup-availability`;
        fetch(url)
          .then(response => response.text())
          .then(text => {
            const html = new DOMParser().parseFromString(text, 'text/html');
            const newContent = html.querySelector('.pickup-availability-wrapper');
            if (newContent) {
              pickupAvailability.innerHTML = newContent.outerHTML;
            } else {
              pickupAvailability.innerHTML = '';
            }
          })
          .catch(e => console.error('Error fetching pickup availability:', e));
      } else if (pickupAvailability && !variant) {
        pickupAvailability.innerHTML = '';
      }
    });

    // Handle Pickup Modal
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('js-show-pickup-drawer')) {
        const modal = e.target.closest('pickup-availability').querySelector('.pickup-availability-modal');
        if (modal) modal.style.display = 'flex';
      }
      if (e.target.classList.contains('js-close-pickup-drawer') || e.target.classList.contains('pickup-availability-modal')) {
        const modal = e.target.closest('.pickup-availability-modal') || e.target;
        modal.style.display = 'none';
      }
    });
  });
</script>

{%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
{%- if first_3d_model -%}
  <script type="application/json" id="ModelJson-{{ section.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script>
    window.ShopifyXR=window.ShopifyXR||function(){(ShopifyXR.q=ShopifyXR.q||[]).push(arguments)};
    ShopifyXR('addModels', JSON.parse(document.getElementById('ModelJson-{{ section.id }}').textContent));
  </script>
  <script src="https://cdn.shopify.com/shopifycloud/shopify-xr-js/assets/v1.0/shopify-xr.en.js" defer></script>
{%- endif -%}
