<div class="product-grid-section" style="padding: 40px 0; background: var(--color-bg); content-visibility: auto; contain-intrinsic-size: 800px;">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div style="text-align: center; margin-bottom: 40px;">
        {%- if section.settings.subheading != blank -%}
          <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 14px; color: var(--color-primary); margin-bottom: 10px;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 style="font-size: clamp(28px, 4vw, 42px);">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <style>
      .product-grid-{{ section.id }} {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
      @media (min-width: 768px) {
        .product-grid-{{ section.id }} { grid-template-columns: repeat(3, 1fr); gap: 30px; }
      }
      @media (min-width: 1024px) {
        .product-grid-{{ section.id }} { grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); }
      }
    </style>

    <div class="product-grid-{{ section.id }}">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection == blank and section.settings.product_list == blank -%}
        {%- assign collection = collections['all'] -%}
      {%- endif -%}

      {%- if section.settings.product_list != blank -%}
        {%- for product in section.settings.product_list limit: section.settings.products_to_show -%}
          {%- assign lazy_load = true -%}
          {% render 'product-card', product_card_product: product, lazy_load: lazy_load, show_secondary_image: true, show_vendor: true, show_rating: true %}
        {%- endfor -%}
      {%- elsif collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- assign lazy_load = true -%}
          {% render 'product-card', product_card_product: product, lazy_load: lazy_load, show_secondary_image: true, show_vendor: true, show_rating: true %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          {%- assign dummy_title = '' -%}
          {%- assign dummy_vendor = '' -%}
          {%- assign dummy_price = '' -%}
          {%- assign dummy_img = '' -%}
          {%- assign dummy_badge = '' -%}
          
          {%- case i -%}
            {%- when 1 -%}
              {%- assign dummy_title = 'Minimalist Niacinamide Serum' -%}
              {%- assign dummy_vendor = 'Minimalist' -%}
              {%- assign dummy_price = '₹559 <span style="text-decoration: line-through; color: var(--color-text-light); font-size: 12px;">₹699</span>' -%}
              {%- assign dummy_img = 'prod_minimalist.png' -%}
              {%- assign dummy_badge = '<div class="product-badge" style="background: #e91e63;">-20%</div>' -%}
            {%- when 2 -%}
              {%- assign dummy_title = 'Watermelon Moisturizer' -%}
              {%- assign dummy_vendor = 'Dot & Key' -%}
              {%- assign dummy_price = '₹599' -%}
              {%- assign dummy_img = 'prod_dotkey.png' -%}
            {%- when 3 -%}
              {%- assign dummy_title = 'Liquid Lipstick' -%}
              {%- assign dummy_vendor = 'Swiss Beauty' -%}
              {%- assign dummy_price = '₹349 <span style="text-decoration: line-through; color: var(--color-text-light); font-size: 12px;">₹499</span>' -%}
              {%- assign dummy_img = 'prod_swiss.png' -%}
              {%- assign dummy_badge = '<div class="product-badge" style="background: #4caf50;">New</div>' -%}
            {%- when 4 -%}
              {%- assign dummy_title = 'Mamaearth Face Wash' -%}
              {%- assign dummy_vendor = 'Mamaearth' -%}
              {%- assign dummy_price = '₹399 <span style="text-decoration: line-through; color: var(--color-text-light); font-size: 12px;">₹499</span>' -%}
              {%- assign dummy_img = 'prod_mamaearth.png' -%}
              {%- assign dummy_badge = '<div class="product-badge" style="background: #e91e63;">-15%</div>' -%}
            {%- when 5 -%}
              {%- assign dummy_title = 'Pilgrim Vitamin C Serum' -%}
              {%- assign dummy_vendor = 'Pilgrim' -%}
              {%- assign dummy_price = '₹449' -%}
              {%- assign dummy_img = 'prod_pilgrim.png' -%}
              {%- assign dummy_badge = '<div class="product-badge" style="background: #ff9800;">Bestseller</div>' -%}
            {%- when 6 -%}
              {%- assign dummy_title = 'Matte Lipstick' -%}
              {%- assign dummy_vendor = 'Nykaa' -%}
              {%- assign dummy_price = '₹449 <span style="text-decoration: line-through; color: var(--color-text-light); font-size: 12px;">₹599</span>' -%}
              {%- assign dummy_img = 'prod_nykaa.png' -%}
          {%- endcase -%}

          <div class="product-card">
            <div class="product-card-image-wrapper">
              <a href="{{ routes.all_products_collection_url }}" class="product-card-link">
                <img src="{{ dummy_img | asset_url }}" alt="{{ dummy_title }}" class="product-card-image" loading="lazy" width="400" height="400">
              </a>
              {{ dummy_badge }}

            </div>
          
            <div class="product-card-info">
              <div class="product-card-brand">{{ dummy_vendor }}</div>
              
              <h3 class="product-card-title">
                <a href="{{ routes.all_products_collection_url }}">{{ dummy_title }}</a>
              </h3>
          
              <div class="product-card-price">{{ dummy_price }}</div>
          
              <div class="product-card-actions" style="margin-top: 15px;">
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="1">
                  <button type="submit" class="btn btn-primary btn-full" style="border-radius: 6px;">{{ 'products.product.add_to_cart' | t }}</button>
                </form>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div style="text-align: center; margin-top: 50px;">
        <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="btn btn-primary" style="padding: 15px 40px; font-size: 16px; letter-spacing: 1px;">
          {{ 'collections.general.view_all' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Top Rated"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Or Select Products Manually",
      "limit": 12
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Maximum products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View All' button"
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}
