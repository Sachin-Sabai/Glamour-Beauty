<div class="customer-reviews" style="padding: 40px 0; background-color: {{ section.settings.bg_color }}; text-align: center;">
  <div class="container">
    <div style="display: flex; flex-direction: column; align-items: center; max-width: 600px; margin: 0 auto;">
      <h2 style="font-family: var(--font-heading); font-size: clamp(28px, 4vw, 36px); margin-bottom: 15px;">Loved by Our Customers</h2>
      <p style="font-size: 16px; color: var(--color-text-light);">Our products are crafted to deliver real results. Join our community of beautiful, confident customers.</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Reviews Summary",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF4F4"
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews Summary"
    }
  ]
}
{% endschema %}
