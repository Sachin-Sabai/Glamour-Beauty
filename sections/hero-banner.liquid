{%- style -%}
  .hero-banner-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    background-color: {{ section.settings.bg_color }};
    min-height: {{ section.settings.min_height }}px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .hero-banner-content-wrap {
    flex: 1 1 50%;
    padding: 60px 5%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 2;
  }
  .hero-banner-image-wrap {
    flex: 1 1 50%;
    position: relative;
    height: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-banner-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }
  @media (max-width: 767px) {
    .hero-banner-content-wrap, .hero-banner-image-wrap {
      flex: 1 1 100%;
    }
    .hero-banner-image-wrap {
      min-height: auto;
      height: auto;
    }
    .hero-banner-image-wrap img {
      position: relative;
      height: auto;
      object-fit: contain;
      object-position: center;
    }
  }
  .hero-eyebrow {
    font-family: var(--font-accent);
    font-size: clamp(32px, 4vw, 48px);
    color: var(--color-primary);
    margin-bottom: -10px;
    line-height: 1;
    z-index: 1;
  }
  .hero-heading {
    font-size: clamp(40px, 6vw, 72px);
    margin-bottom: 20px;
    color: var(--color-text);
    line-height: 1.1;
    font-weight: 600;
  }
  .hero-text {
    font-size: clamp(16px, 2vw, 18px);
    margin-bottom: 30px;
    color: var(--color-text-light);
    max-width: 450px;
  }
  .hero-buttons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }
  .hero-badge-overlay {
    position: absolute;
    top: 20px;
    right: 20px;
    background: #fff;
    color: var(--color-primary);
    padding: 10px 20px;
    border-radius: 30px;
    font-weight: 600;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    z-index: 3;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
{%- endstyle -%}

<div class="hero-banner-{{ section.id }}">
  <div class="hero-banner-content-wrap">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero-eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="hero-text">{{ section.settings.text }}</div>
    {%- endif -%}
    
    <div class="hero-buttons">
      {%- if section.settings.btn1_label != blank -%}
        {%- assign btn1_url = section.settings.btn1_collection.url | default: '/collections/all?sort_by=best-selling' -%}
        <a href="{{ btn1_url }}" class="btn btn-primary">{{ section.settings.btn1_label }}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="hero-banner-image-wrap">
    {%- if section.settings.show_badge -%}
      <div class="hero-badge-overlay">{{ section.settings.badge_text }}</div>
    {%- endif -%}
        {%- assign hero_image = section.settings.image -%}
        {%- if hero_image == blank -%}
          {%- assign hero_image = images['hero_model.png'] -%}
        {%- endif -%}
        
        {%- if hero_image != blank -%}
          {{ hero_image | image_url: width: 2000 | image_tag: widths: '375, 550, 750, 1100, 1500, 1780, 2000', loading: 'eager', fetchpriority: 'high', style: 'width: 100%; height: 100%; object-fit: cover; object-position: right 20%;', sizes: '(max-width: 767px) 100vw, 50vw' }}
        {%- else -%}
          <img src="{{ 'hero_model.png' | asset_url }}" alt="Hero Model" width="1024" height="1024" loading="eager" fetchpriority="high" style="width: 100%; height: 100%; object-fit: cover; object-position: right 20%;">
        {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner Split",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF4F4"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "default": 600,
      "label": "Minimum Height (px)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text (Cursive)",
      "default": "Unleash Your"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Natural Beauty"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subheading",
      "default": "Discover our new collection of organic skincare products designed to nourish and rejuvenate your skin."
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "collection",
      "id": "btn1_collection",
      "label": "Primary Button Collection"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Floating Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "NEW ARRIVALS"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner Split"
    }
  ]
}
{% endschema %}
