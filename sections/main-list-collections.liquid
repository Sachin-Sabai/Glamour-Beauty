<div class="list-collections-section" style="padding: 80px 0; background: var(--color-bg);">
  <div class="container">
    <h1 style="text-align: center; font-size: clamp(32px, 5vw, 48px); margin-bottom: 50px; font-weight: 600;">{{ section.settings.title | default: 'Our Collections' }}</h1>
    
    <div class="collections-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px;">
      {%- for collection in collections -%}
        {%- if collection.handle != 'frontpage' and collection.all_products_count > 0 -%}
          <div class="collection-card" style="position: relative; overflow: hidden; border-radius: var(--border-radius); box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
            <a href="{{ collection.url }}" style="display: block; width: 100%; height: 100%; text-decoration: none;">
              <div class="collection-card-image" style="position: relative; height: 350px;">
                {%- if collection.image -%}
                  <img src="{{ collection.image | image_url: width: 600 }}" width="600" height="600" alt="{{ collection.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                {%- elsif collection.products.first and collection.products.first.featured_image -%}
                  <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" width="600" height="600" alt="{{ collection.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 50%);"></div>
              </div>
              <div class="collection-card-info" style="position: absolute; bottom: 0; left: 0; width: 100%; padding: 30px 20px; color: #fff;">
                <h3 style="font-size: 24px; font-weight: 600; margin-bottom: 5px;">{{ collection.title }}</h3>
                <span style="font-size: 14px; opacity: 0.9;">{{ collection.all_products_count }} products</span>
              </div>
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .collection-card:hover {
    transform: translateY(-5px);
  }
  .collection-card:hover .collection-card-image img {
    transform: scale(1.05);
    transition: transform 0.5s ease;
  }
  .collection-card-image img {
    transition: transform 0.5s ease;
  }
</style>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Collections"
    }
  ]
}
{% endschema %}
