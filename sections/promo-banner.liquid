<div class="promo-banner" style="background-color: {{ section.settings.bg_color }}; margin: 60px 0;">
  <div class="container">
    <div style="display: flex; flex-wrap: wrap; align-items: center; border-radius: 20px; overflow: hidden; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
      <div style="flex: 1 1 50%; padding: 40px 5%; order: 2;">
        {%- if section.settings.subheading != blank -%}
          <p style="font-family: var(--font-accent); font-size: 32px; color: var(--color-primary); margin-bottom: 0px; line-height: 1;">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <h2 style="font-family: var(--font-heading); font-size: clamp(32px, 5vw, 48px); margin-bottom: 20px; color: var(--color-text); line-height: 1.1;">{{ section.settings.heading }}</h2>
        <p style="font-size: 16px; color: var(--color-text-light); margin-bottom: 30px;">{{ section.settings.text }}</p>
        
        <div style="display: flex; gap: 20px; margin-bottom: 30px;">
          <div style="display: flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span style="font-size: 13px; font-weight: 500;">Cruelty Free</span>
          </div>
          <div style="display: flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span style="font-size: 13px; font-weight: 500;">Paraben Free</span>
          </div>
        </div>

        <a href="{{ section.settings.btn_link }}" class="btn btn-primary" style="padding: 15px 40px; font-size: 16px; letter-spacing: 1px;">{{ section.settings.btn_label }}</a>
      </div>
      
      <div style="flex: 1 1 50%; min-height: 400px; position: relative; order: 1;">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', style: 'position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;', sizes: '(max-width: 767px) 100vw, 50vw' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' | replace: '<svg', '<svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;"' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
<style>
  @media (max-width: 767px) {
    .promo-banner > .container > div > div { flex: 1 1 100%; }
    .promo-banner > .container > div > div:nth-child(2) { order: 1; min-height: 300px; }
    .promo-banner > .container > div > div:nth-child(1) { order: 2; padding: 40px 20px; text-align: center; }
    .promo-banner > .container > div > div:nth-child(1) > div { justify-content: center; }
  }
</style>

{% schema %}
{
  "name": "Promo Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Special Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Up to 30% OFF on Bestsellers"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Treat yourself to our top-rated beauty essentials at unbeatable prices."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Sale Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
