<div class="customer reset-password" style="max-width: 500px; margin: 50px auto; padding: 20px;">
  <h1 style="text-align: center; margin-bottom: 20px;">Reset account password</h1>
  <p style="text-align: center; margin-bottom: 20px;">Enter a new password for your account</p>
  
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}
      <h2 class="form__message" tabindex="-1" autofocus style="color: red;">
        <span class="visually-hidden">Error </span>
        Please adjust the following:
      </h2>
      {{ form.errors | default_errors }}
    {%- endif -%}

    <div class="field" style="margin-bottom: 15px;">
      <label for="password" class="visually-hidden">Password</label>
      <input type="password" name="customer[password]" id="password" autocomplete="new-password" {% if form.errors contains 'password' %}aria-invalid="true"{% endif %} placeholder="Password" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--border-radius);">
    </div>

    <div class="field" style="margin-bottom: 20px;">
      <label for="password_confirmation" class="visually-hidden">Confirm password</label>
      <input type="password" name="customer[password_confirmation]" id="password_confirmation" autocomplete="new-password" {% if form.errors contains 'password_confirmation' %}aria-invalid="true"{% endif %} placeholder="Confirm password" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--border-radius);">
    </div>

    <button style="width: 100%; padding: 10px; background: var(--color-primary); color: white; border: none; border-radius: var(--border-radius); cursor: pointer;">Reset password</button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Reset Password",
  "settings": []
}
{% endschema %}
