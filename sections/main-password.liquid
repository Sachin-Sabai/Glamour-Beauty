<div class="password-main-content" style="text-align: center; max-width: 500px; width: 100%; margin: 0 auto; display: flex; flex-direction: column; gap: 40px;">
  
  <div>
    <h2 style="font-size: clamp(28px, 4vw, 42px); margin-bottom: 15px; font-family: var(--font-heading);">{{ section.settings.heading }}</h2>
    <p style="color: var(--color-text-light); margin-bottom: 30px; font-size: 16px;">{{ section.settings.text }}</p>
    
    {%- if section.settings.show_newsletter -%}
      {% form 'customer', class: 'password-form' %}
        <input type="hidden" name="contact[tags]" value="prospect, password page">
        <div style="display: flex; gap: 10px; margin-bottom: 15px; flex-direction: column; sm-flex-direction: row;">
          <label for="Email" class="visually-hidden">Email address</label>
          <input type="email"
            name="contact[email]"
            id="Email"
            spellcheck="false"
            autocomplete="email"
            autocapitalize="off"
            class="form-input"
            placeholder="Email address"
            required
            style="flex-grow: 1; border: 1px solid var(--color-border); padding: 12px; border-radius: 4px;"
          >
          <button type="submit" name="commit" class="btn btn-primary" style="white-space: nowrap;">
            Notify me
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <div style="color: #2e7d32; font-size: 14px; background: #e8f5e9; padding: 10px; border-radius: 4px;">Thanks for subscribing! We'll be in touch.</div>
        {%- endif -%}
        {%- if form.errors -%}
          <div style="color: #c62828; font-size: 14px; background: #ffebee; padding: 10px; border-radius: 4px;">{{ form.errors | default_errors }}</div>
        {%- endif -%}
      {% endform %}
    {%- endif -%}
  </div>

  <div style="padding-top: 40px; border-top: 1px solid var(--color-border);">
    <h2 style="font-size: clamp(24px, 3vw, 32px); margin-bottom: 15px; font-family: var(--font-heading);">Enter store using password</h2>
    
    {% form 'storefront_password', class: 'password-form' %}
      <div style="display: flex; gap: 10px; margin-bottom: 15px; flex-direction: column; sm-flex-direction: row;">
        <label for="Password" class="visually-hidden">Your password</label>
        <input type="password"
          name="password"
          id="Password"
          class="form-input"
          autocomplete="current-password"
          placeholder="Your password"
          style="flex-grow: 1; border: 1px solid var(--color-border); padding: 12px; border-radius: 4px;"
        >
        <button type="submit" name="commit" class="btn btn-primary">
          Enter
        </button>
      </div>
      {%- if form.errors -%}
        <div style="color: #c62828; font-size: 14px; margin-bottom: 15px; background: #ffebee; padding: 10px; border-radius: 4px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}
    {% endform %}
    
    <p style="font-size: 14px; color: var(--color-text-light); margin-top: 20px;">Are you the store owner? <a href="/admin" style="text-decoration: underline; color: var(--color-primary);">Log in here</a></p>
  </div>
</div>

{% schema %}
{
  "name": "Password Main",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Be the first to know when we launch."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ]
}
{% endschema %}
