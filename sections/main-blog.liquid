<div class="blog-template" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container">
    <h1 style="text-align: center; font-size: clamp(36px, 5vw, 54px); margin-bottom: 40px;">{{ blog.title }}</h1>

    {%- paginate blog.articles by section.settings.posts_per_page -%}
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px;">
        {%- for article in blog.articles -%}
          <article class="blog-card" style="background: #fff; border-radius: var(--border-radius); overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
            <a href="{{ article.url }}" style="display: block; text-decoration: none; color: inherit;">
              {%- if article.image -%}
                <div style="aspect-ratio: 16/9; overflow: hidden;">
                  <img width="400" height="400" src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                </div>
              {%- else -%}
                <div style="aspect-ratio: 16/9; background: var(--color-secondary); display: flex; align-items: center; justify-content: center;">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}
              
              <div style="padding: 30px;">
                <div style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--color-primary); margin-bottom: 10px;">
                  {{ article.published_at | time_tag: format: 'date' }}
                </div>
                <h2 style="font-family: var(--font-heading); font-size: 24px; margin-bottom: 15px; line-height: 1.3;">{{ article.title }}</h2>
                <div style="color: var(--color-text-light); font-size: 14px; line-height: 1.6; margin-bottom: 20px;">
                  {%- if article.excerpt.size > 0 -%}
                    {{ article.excerpt }}
                  {%- else -%}
                    {{ article.content | strip_html | truncatewords: 25 }}
                  {%- endif -%}
                </div>
                <span style="font-weight: 600; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: var(--color-text); display: flex; align-items: center; gap: 5px;">
                  Read More <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
            <style>
              .blog-card:hover { transform: translateY(-5px); }
              .blog-card:hover img { transform: scale(1.05); }
            </style>
          </article>
        {%- endfor -%}
      </div>
      
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog Layout",
  "settings": [
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 9,
      "label": "Posts per page"
    }
  ]
}
{% endschema %}
