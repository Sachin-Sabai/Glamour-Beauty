<div class="password-header" style="padding: 20px 40px; display: flex; justify-content: center; align-items: center; border-bottom: 1px solid var(--color-border);">
  <div class="password-logo">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="150" height="150" style="max-width: {{ settings.logo_width | default: 150 }}px; height: auto;">
    {%- else -%}
      <h1 style="font-size: 24px; margin: 0; font-family: var(--font-heading);">{{ shop.name }}</h1>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Password Header"
}
{% endschema %}
