{%- if blog.articles.size > 1 -%}
<div class="article-related" style="padding: 40px 0; background: var(--color-bg); border-top: 1px solid var(--color-border);">
  <div class="container">
    <h2 style="text-align: center; font-size: 32px; margin-bottom: 40px;">Read More</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px;">
      {%- assign current_article_id = article.id -%}
      {%- assign counter = 0 -%}
      {%- for related_article in blog.articles -%}
        {%- if related_article.id != current_article_id and counter < 3 -%}
          <article class="blog-card" style="background: #fff; border-radius: var(--border-radius); overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
            <a href="{{ related_article.url }}" style="display: block; text-decoration: none; color: inherit;">
              {%- if related_article.image -%}
                <div style="aspect-ratio: 16/9; overflow: hidden;">
                  <img width="400" height="400" src="{{ related_article.image | image_url: width: 600 }}" alt="{{ related_article.image.alt | escape }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                </div>
              {%- endif -%}
              <div style="padding: 20px;">
                <h3 style="font-family: var(--font-heading); font-size: 20px; margin-bottom: 10px; line-height: 1.3;">{{ related_article.title }}</h3>
                <span style="font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--color-primary); display: flex; align-items: center; gap: 5px;">
                  Read More <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          </article>
          {%- assign counter = counter | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Related Articles",
  "settings": []
}
{% endschema %}
