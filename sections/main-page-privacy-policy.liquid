<div class="privacy-policy-page" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container" style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-size: clamp(32px, 5vw, 48px); margin-bottom: 40px; text-align: center; border-bottom: 2px solid var(--color-primary); padding-bottom: 20px; display: inline-block;">{{ page.title }}</h1>
    
    <div class="rte" style="line-height: 1.8; font-size: 16px; color: var(--color-text);">
      {{ page.content }}
    </div>
    
    <style>
      .privacy-policy-page .rte h2 { margin-top: 40px; margin-bottom: 20px; font-size: 24px; color: var(--color-text); }
      .privacy-policy-page .rte h3 { margin-top: 30px; margin-bottom: 15px; font-size: 20px; }
      .privacy-policy-page .rte p { margin-bottom: 20px; color: var(--color-text-light); }
      .privacy-policy-page .rte ul { margin-bottom: 20px; padding-left: 20px; color: var(--color-text-light); }
      .privacy-policy-page .rte li { margin-bottom: 10px; }
    </style>
  </div>
</div>

{% schema %}
{
  "name": "Privacy Policy",
  "settings": []
}
{% endschema %}
