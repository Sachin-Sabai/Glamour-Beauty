<div class="contact-page" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container" style="max-width: 800px; margin: 0 auto;">
    <h1 style="font-size: clamp(36px, 5vw, 54px); margin-bottom: 20px; text-align: center;">{{ page.title }}</h1>
    
    {%- if page.content != blank -%}
      <div class="rte" style="line-height: 1.8; margin-bottom: 40px; text-align: center;">
        {{ page.content }}
      </div>
    {%- endif -%}

    <div style="background: #fff; padding: 40px; border-radius: var(--border-radius); box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div style="padding: 15px; background: #E8F5E9; color: #2E7D32; border-radius: var(--border-radius); margin-bottom: 20px; text-align: center; font-weight: 500;">
            {{ 'contact.form.post_success' | t }}
          </div>
        {%- elsif form.errors -%}
          <div style="padding: 15px; background: #FFEBEE; color: #C62828; border-radius: var(--border-radius); margin-bottom: 20px;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px;">
          <div>
            <label for="ContactForm-name" style="display: block; margin-bottom: 5px; font-weight: 500;">{{ 'contact.form.name' | t }}</label>
            <input type="text" id="ContactForm-name" name="contact[{{ 'contact.form.name' | t }}]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" class="form-input" style="width: 100%;">
          </div>
          <div>
            <label for="ContactForm-email" style="display: block; margin-bottom: 5px; font-weight: 500;">{{ 'contact.form.email' | t }} <span style="color: red;">*</span></label>
            <input type="email" id="ContactForm-email" name="contact[email]" autocorrect="off" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" required class="form-input" style="width: 100%;">
          </div>
        </div>

        <div style="margin-bottom: 20px;">
          <label for="ContactForm-phone" style="display: block; margin-bottom: 5px; font-weight: 500;">{{ 'contact.form.phone' | t }}</label>
          <input type="tel" id="ContactForm-phone" name="contact[{{ 'contact.form.phone' | t }}]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" class="form-input" style="width: 100%;">
        </div>

        <div style="margin-bottom: 30px;">
          <label for="ContactForm-body" style="display: block; margin-bottom: 5px; font-weight: 500;">{{ 'contact.form.message' | t }}</label>
          <textarea id="ContactForm-body" name="contact[{{ 'contact.form.message' | t }}]" rows="6" class="form-input" style="width: 100%;">{{ form.body }}</textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-full">{{ 'contact.form.send' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "settings": []
}
{% endschema %}
