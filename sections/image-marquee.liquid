<div class="image-marquee-section" style="padding: 40px 0; background-color: {{ section.settings.bg_color }}; overflow: hidden;">
  {%- if section.settings.heading != blank -%}
    <h2 style="text-align: center; font-size: clamp(28px, 4vw, 42px); margin-bottom: 40px; font-family: var(--font-heading);">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="marquee-wrapper" style="display: flex; width: 200%; animation: scrollMarquee {{ section.settings.speed }}s linear infinite;">
    <div style="display: flex; width: 50%; justify-content: space-around; align-items: center;">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="marquee-image-item" style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 5px solid #fff; margin: 0 15px;">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
            {%- else -%}
              <img src="{{ 'prod_minimalist.png' | asset_url }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Dummy Images -->
        {%- assign images = 'prod_minimalist.png,prod_dotkey.png,prod_swiss.png,prod_mamaearth.png,brand_philosophy.png' | split: ',' -%}
        {%- for img in images -%}
          <div class="marquee-image-item" style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 5px solid #fff; margin: 0 15px;">
            <img src="{{ img | asset_url }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div style="display: flex; width: 50%; justify-content: space-around; align-items: center;">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="marquee-image-item" style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 5px solid #fff; margin: 0 15px;">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
            {%- else -%}
              <img src="{{ 'prod_minimalist.png' | asset_url }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Dummy Images -->
        {%- assign images = 'prod_minimalist.png,prod_dotkey.png,prod_swiss.png,prod_mamaearth.png,brand_philosophy.png' | split: ',' -%}
        {%- for img in images -%}
          <div class="marquee-image-item" style="width: 200px; height: 200px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 5px solid #fff; margin: 0 15px;">
            <img src="{{ img | asset_url }}" width="400" height="400" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  @keyframes scrollMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .marquee-wrapper:hover {
    animation-play-state: paused;
  }
  @media (max-width: 768px) {
    .marquee-image-item { width: 140px !important; height: 140px !important; }
  }
</style>

{% schema %}
{
  "name": "Round Image Marquee",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF4F4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Gallery"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Animation Speed",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Round Image Marquee"
    }
  ]
}
{% endschema %}
