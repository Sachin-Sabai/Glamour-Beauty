<div class="beauty-routine" style="padding: 60px 0; background: var(--color-bg);">
  <div class="container">
    <div style="text-align: center; margin-bottom: 50px;">
      {%- if section.settings.subheading != blank -%}
        <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 14px; color: var(--color-primary); margin-bottom: 10px;">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="font-size: clamp(28px, 4vw, 42px); font-family: var(--font-heading);">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div style="position: relative; max-width: 800px; margin: 0 auto;">
      <div class="routine-line" style="position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; background: var(--color-border); transform: translateX(-50%); z-index: 1;"></div>
      
      <div style="display: flex; flex-direction: column; gap: 40px; position: relative; z-index: 2;">
        {%- for block in section.blocks -%}
          <div class="routine-step" {{ block.shopify_attributes }} style="display: flex; align-items: center; justify-content: space-between; width: 100%; flex-direction: {% cycle 'row', 'row-reverse' %};">
            
            <div style="width: 45%; {% cycle 'text-align: right;', 'text-align: left;' %}">
              <h3 style="font-size: 24px; font-family: var(--font-heading); margin-bottom: 10px;">Step {{ forloop.index }}: {{ block.settings.title }}</h3>
              <p style="font-size: 15px; color: var(--color-text-light); line-height: 1.6; margin-bottom: 15px;">{{ block.settings.text }}</p>
              {%- if block.settings.product != blank -%}
                <a href="{{ block.settings.product.url }}" class="btn btn-secondary" style="font-size: 13px; padding: 8px 16px;">Shop {{ block.settings.product.title }}</a>
              {%- endif -%}
            </div>

            <div style="width: 10%; display: flex; justify-content: center;">
              <div style="width: 40px; height: 40px; background: var(--color-primary); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-family: var(--font-heading); font-size: 18px; border: 4px solid var(--color-bg);">{{ forloop.index }}</div>
            </div>

            <div style="width: 45%;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 600 }}" width="400" height="400" alt="{{ block.settings.title }}" style="width: 100%; border-radius: var(--border-radius); box-shadow: 0 10px 30px rgba(0,0,0,0.05); object-fit: cover;">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .routine-line { left: 20px !important; transform: none !important; }
    .routine-step { flex-direction: column !important; align-items: flex-start !important; }
    .routine-step > div:nth-child(1) { width: 100% !important; text-align: left !important; padding-left: 60px; order: 2; margin-bottom: 20px; }
    .routine-step > div:nth-child(2) { width: auto !important; position: absolute; left: 0; top: 0; }
    .routine-step > div:nth-child(3) { width: 100% !important; padding-left: 60px; order: 1; margin-bottom: 20px; }
  }
</style>

{% schema %}
{
  "name": "Beauty Routine",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Daily Glow Routine"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Step by Step"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Routine Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Cleanse"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Start with a clean slate to remove impurities and prepare your skin."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Recommended Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beauty Routine",
      "blocks": [
        { "type": "step", "settings": { "title": "Cleanse" } },
        { "type": "step", "settings": { "title": "Tone" } },
        { "type": "step", "settings": { "title": "Moisturize" } }
      ]
    }
  ]
}
{% endschema %}
