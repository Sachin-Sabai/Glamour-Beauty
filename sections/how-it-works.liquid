<div class="how-it-works-section" style="padding: 40px 0; background: var(--color-bg);">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 style="text-align: center; font-size: clamp(28px, 4vw, 42px); margin-bottom: 60px;">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="steps-container" style="position: relative; display: grid; gap: 40px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
      
      <!-- Desktop Connecting Line -->
      <div class="connecting-line show-desktop" style="position: absolute; top: 40px; left: 10%; right: 10%; height: 2px; background: var(--color-border); z-index: 1; display: none;"></div>

      {%- for block in section.blocks -%}
        <div class="step-card" {{ block.shopify_attributes }} style="position: relative; z-index: 2; text-align: center;">
          <div class="step-number" style="width: 40px; height: 40px; background: var(--color-primary); color: var(--color-button-text); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 18px; margin: 0 auto 20px; box-shadow: 0 0 0 10px var(--color-bg);">
            {{ forloop.index }}
          </div>
          
          <div class="step-icon" style="height: 60px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center;">
            {%- if block.settings.icon != blank -%}
              <img width="400" height="400" src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title }}" style="max-height: 100%;">
            {%- else -%}
              <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="var(--color-primary)" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4M12 8h.01"></path></svg>
            {%- endif -%}
          </div>
          
          <h3 style="font-size: 20px; margin-bottom: 10px;">{{ block.settings.title }}</h3>
          <p style="font-size: 14px; color: var(--color-text-light);">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
    <style>
      @media (min-width: 768px) { .how-it-works-section .show-desktop { display: block !important; } }
    </style>
  </div>
</div>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Skincare Routine"
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cleanse"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Start with a clean canvas to allow products to absorb effectively."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        { "type": "step", "settings": { "title": "Cleanse" } },
        { "type": "step", "settings": { "title": "Tone" } },
        { "type": "step", "settings": { "title": "Treat" } },
        { "type": "step", "settings": { "title": "Moisturize" } }
      ]
    }
  ]
}
{% endschema %}
