<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ shop.name }}</title>

    <meta name="description" content="{{ page_description | escape }}">
    
    {%- assign font_heading = settings.font_heading -%}
    {%- assign font_body = settings.font_body -%}
    {%- assign font_accent = settings.font_accent -%}

    <style>
      {{ font_heading | font_face: font_display: 'swap' }}
      {{ font_body | font_face: font_display: 'swap' }}
      {{ font_accent | font_face: font_display: 'swap' }}
      
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-accent: {{ settings.color_accent }};
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-text-light: {{ settings.color_text_light }};
        --color-border: {{ settings.color_border }};
        --color-button-text: {{ settings.color_button_text }};
        --border-radius: {{ settings.border_radius }}px;
        --font-heading: {{ font_heading.family }}, {{ font_heading.fallback_families }};
        --font-body: {{ font_body.family }}, {{ font_body.fallback_families }};
        --font-accent: {{ font_accent.family }}, {{ font_accent.fallback_families }};
      }
    </style>

    {{ content_for_header }}

    {{ 'theme.css' | asset_url | stylesheet_tag: preload: true }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-password" style="display: flex; flex-direction: column; min-height: 100vh; background-color: var(--color-bg); color: var(--color-text);">
    <a href="#main-content" class="skip-to-content-link">Skip to content</a>

    {% section 'password-header' %}

    <main id="main-content" class="content-for-layout focus-none" role="main" tabindex="-1" style="flex-grow: 1; display: flex; align-items: center; justify-content: center; padding: 40px 20px;">
      {{ content_for_layout }}
    </main>

    {% section 'password-footer' %}

    <div id="toast-container"></div>
  </body>
</html>
