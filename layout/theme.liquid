<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% elsif settings.default_meta_description != blank %}
      <meta name="description" content="{{ settings.default_meta_description | escape }}">
    {% else %}
      <meta name="description" content="{{ shop.description | default: shop.name | escape }}">
    {% endif %}
    {% render 'meta-tags' %}
    
    {%- assign font_heading = settings.font_heading -%}
    {%- assign font_body = settings.font_body -%}
    {%- assign font_accent = settings.font_accent -%}

    <style>
      {{ font_heading | font_face: font_display: 'swap' }}
      {{ font_body | font_face: font_display: 'swap' }}
      {{ font_accent | font_face: font_display: 'swap' }}
      :root {
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-accent: {{ settings.color_accent }};
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-text-light: {{ settings.color_text_light }};
        --color-border: {{ settings.color_border }};
        --color-button-text: {{ settings.color_button_text }};
        --border-radius: {{ settings.border_radius }}px;
        --font-heading: {{ font_heading.family }}, {{ font_heading.fallback_families }};
        --font-body: {{ font_body.family }}, {{ font_body.fallback_families }};
        --font-accent: {{ font_accent.family }}, {{ font_accent.fallback_families }};
        --font-heading-weight: {{ font_heading.weight }};
        --font-heading-style: {{ font_heading.style }};
        --font-body-weight: {{ font_body.weight }};
        --font-body-style: {{ font_body.style }};
      }
    </style>

    {{ content_for_header }}

    {{ 'theme.css' | asset_url | stylesheet_tag: preload: true }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-{{ request.page_type | handle }}">
    <a href="#main-content" class="skip-to-content-link">Skip to content</a>
    <div id="scroll-progress-bar"></div>

    {% sections 'header-group' %}

    {% if settings.enable_cart_drawer %}
      {% section 'cart-drawer' %}
    {% endif %}

    <main id="main-content" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <div id="toast-container"></div>
    
    <button id="back-to-top" aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 15l-6-6-6 6"/></svg>
    </button>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}'
      };

      window.cartStrings = {
        error: `{{ 'cart.general.error' | t | default: 'There was an error while updating your cart. Please try again.' }}`,
        quantityError: `{{ 'cart.general.cart_error' | t: quantity: '[quantity]' | default: 'You can only add [quantity] of this item to your cart.' }}`
      }
    </script>
  </body>
</html>
