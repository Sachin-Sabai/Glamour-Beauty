{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.colors_background_1 }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value_with_amount, shop: shop.name }}</title>
    <meta name="description" content="{{ 'gift_cards.issued.subtext' | t }}">
    
    {{ content_for_header }}
    
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
    
    <style>
      :root {
        --color-primary: {{ settings.colors_primary | default: '#000000' }};
        --color-bg: {{ settings.colors_background_1 | default: '#ffffff' }};
        --color-text: {{ settings.colors_text | default: '#333333' }};
        --font-body: {{ settings.type_body_font.family | default: 'sans-serif' }};
        --font-heading: {{ settings.type_header_font.family | default: 'sans-serif' }};
      }
      body {
        font-family: var(--font-body);
        background-color: var(--color-bg);
        color: var(--color-text);
        margin: 0;
        padding: 40px 20px;
        text-align: center;
      }
      .gift-card-wrapper {
        max-width: 600px;
        margin: 0 auto;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        padding: 40px;
      }
      .shop-logo { font-family: var(--font-heading); font-size: 24px; font-weight: bold; margin-bottom: 30px; }
      .shop-logo img { max-width: 150px; height: auto; }
      .gift-card__title { font-size: 28px; font-family: var(--font-heading); margin-bottom: 10px; }
      .gift-card__price { font-size: 32px; font-weight: bold; margin: 20px 0; }
      .gift-card__qr-code { display: flex; justify-content: center; margin: 30px 0; }
      .gift-card__qr-code img { width: 120px; height: 120px; }
      .gift-card__code { 
        background: #f4f4f4; 
        padding: 15px; 
        font-size: 20px; 
        letter-spacing: 2px; 
        font-family: monospace; 
        border-radius: 4px;
        margin-bottom: 20px;
      }
      .btn {
        display: inline-block;
        background: var(--color-primary);
        color: #fff;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        margin: 10px;
      }
      .btn--secondary {
        background: #f4f4f4;
        color: var(--color-text);
      }
      .gift-card__expired, .gift-card__disabled {
        color: #d9534f;
        font-weight: bold;
        margin-bottom: 20px;
      }
      .gift-card__apple-wallet {
        margin-top: 20px;
      }
      @media print {
        @page { margin: 0.5cm; }
        p, h2, h3 { orphans: 3; widows: 3; }
        h2, h3 { page-break-after: avoid; }
        body { background: #fff; padding: 0; }
        .gift-card-wrapper { box-shadow: none; padding: 0; }
        .no-print { display: none !important; }
      }
    </style>
  </head>
  <body>
    <div class="gift-card-wrapper">
      <div class="shop-logo">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 150 }}" alt="{{ shop.name }}" loading="lazy" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}">
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </div>

      <h1 class="gift-card__title">Here's your gift card!</h1>

      <div class="gift-card__price">
        {%- if gift_card.enabled == false or gift_card.expired -%}
          <p class="gift-card__disabled">This gift card has expired or is disabled.</p>
        {%- endif -%}
        
        <p>Value: {{ gift_card.initial_value | money }}</p>
        {%- if gift_card.balance != gift_card.initial_value -%}
          <p style="font-size: 16px; font-weight: normal;">Remaining balance: {{ gift_card.balance | money }}</p>
        {%- endif -%}
      </div>

      {%- if gift_card.expires_on -%}
        <p class="gift-card__text">
          Expires on {{ gift_card.expires_on | date: "%B %d, %Y" }}
        </p>
      {%- endif -%}

      <div class="gift-card__qr-code" data-identifier="{{ gift_card.qr_identifier }}"></div>

      <div class="gift-card__code">
        {{ gift_card.code | format_code }}
      </div>
      
      <p style="font-size: 14px; margin-bottom: 30px;">Use this code at checkout to redeem your gift card.</p>

      <div class="gift-card__buttons no-print">
        <button class="btn" onclick="window.print();">Print Gift Card</button>
        <a href="{{ shop.url }}" class="btn btn--secondary" target="_blank" rel="noopener">
          Continue Shopping
        </a>
        <button class="btn btn--secondary" onclick="copyGiftCardCode()">Copy Code</button>
      </div>

      {%- if gift_card.pass_url -%}
        <div class="gift-card__apple-wallet no-print">
          <a href="{{ gift_card.pass_url }}">
            <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" width="120" height="40" alt="Add to Apple Wallet" loading="lazy">
          </a>
        </div>
      {%- endif -%}
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        new QRCode(document.querySelector('.gift-card__qr-code'), {
          text: document.querySelector('.gift-card__qr-code').dataset.identifier,
          width: 120,
          height: 120
        });
      });

      function copyGiftCardCode() {
        const code = "{{ gift_card.code }}";
        navigator.clipboard.writeText(code).then(function() {
          alert('Gift card code copied to clipboard');
        });
      }
    </script>
  </body>
</html>
